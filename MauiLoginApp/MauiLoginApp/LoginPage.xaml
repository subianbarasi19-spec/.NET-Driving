<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiLoginApp.LoginPage"
             Title="Login" Padding="20" BackgroundColor="White">
    <ScrollView>
        <VerticalStackLayout>
            <Label  
            Text="Welcome to .NET MAUI!"
            VerticalOptions="Center" 
            HorizontalOptions="Center" TextColor="Black" FontAttributes="Bold" FontSize="32" />

            <Label Text="Username" FontSize="14" TextColor="Black"></Label>
            <Border Stroke="Grey" StrokeThickness="1" Background="White" StrokeShape="Roundrectangle 10">
                <Entry
                    x:Name="UsernameEntry"
                    Placeholder="Enter Your Username"
                    FontSize="16"
                    TextColor="Black"
                    BackgroundColor="Transparent" PlaceholderColor="Black"
                    Margin="10,0"/>
            </Border>
            <Label Text="Password" FontSize="14" TextColor="Black"></Label>
            <Border Stroke="Grey" StrokeThickness="1" BackgroundColor="White" StrokeShape="Roundrectangle 10">
                <Entry
                    x:Name="PasswordEntry"
                    Placeholder="Enter Your Password"
                    FontSize="16"
                    TextColor="Black"
                    BackgroundColor="Transparent" PlaceholderColor="Black"
                    Margin="10,0"/>
            </Border>

            <Button
                Text="Login"
                BackgroundColor="Blue"
                TextColor="Black"
                FontSize="32"
                CornerRadius="10"
                WidthRequest="150"
                Clicked="Button_Clicked"/>


            <Label Text="Don't have an account? Register"
                   HorizontalOptions="Center"
                   TextColor="Black"
                   FontSize="14">
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>